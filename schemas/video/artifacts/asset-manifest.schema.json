{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vclaw-video-core/video/artifacts/asset-manifest",
  "type": "object",
  "required": ["projectSlug", "assets"],
  "properties": {
    "projectSlug": { "type": "string" },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "path"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "path": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
