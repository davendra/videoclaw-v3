  "required": ["projectSlug", "verdict", "generatedAt"],
  "properties": {
    "projectSlug": { "type": "string" },
    "verdict": { "type": "string", "enum": ["pass", "retry", "fail"] },
    "generatedAt": { "type": "string" }
  },
  "additionalProperties": true
}
